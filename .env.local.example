# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here

# Supabase (create free account at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Solo server: non usare mai il prefisso NEXT_PUBLIC_ per questa chiave.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (piano Professionale — Checkout + abbonamento con prova 7 giorni)
# Dashboard: https://dashboard.stripe.com — crea un Product con prezzo ricorrente mensile (es. 49 €) e copia il Price ID (price_...).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_PROFESSIONAL=price_...
# Opzionale: segreto webhook (es. checkout.session.completed) — endpoint POST /api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...
